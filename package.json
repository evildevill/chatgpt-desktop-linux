{
  "name": "chatgpt-desktop-linux",
  "version": "1.0.1",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux snap",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "build": {
    "productName": "ChatGPT",
    "appId": "com.evildevill.chatgptdesktoplinux",
    "linux": {
      "target": "snap",
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  },
  "repository": "https://github.com/xanmoy/chatgpt-desktop-client.git",
  "keywords": [
    "Electron",
    "ChatGPT",
    "chatgptdesktop",
    "Linux",
    "desktopApplication"
  ],
  "author": "Tanmoy Ganguly",
  "license": "ISC",
  "description": "A simple and efficient desktop client for ChatGPT.",
  "devDependencies": {
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.2"
  },
  "dependencies": {
    "electron-context-menu": "^4.1.1"
  }
}
