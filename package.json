{
  "name": "chatgpt-desktop-linux",
  "version": "1.0.2",
  "description": "A simple and efficient desktop client for ChatGPT.",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux",
    "dist:snap": "electron-builder --linux snap",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evildevill/chatgpt-desktop-linux.git"
  },
  "keywords": [
    "electron",
    "chatgpt",
    "desktop",
    "linux"
  ],
  "author": "evildevill",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/evildevill/chatgpt-desktop-linux/issues"
  },
  "homepage": "https://github.com/evildevill/chatgpt-desktop-linux#readme",
  "dependencies": {
    "electron-context-menu": "^4.1.1"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "prettier": "^3.4.2"
  },
"build": {
  "productName": "ChatGPT",
  "appId": "com.evildevill.chatgptdesktoplinuxz",
  "linux": {
    "target": [
      "snap",
      "AppImage",
      "deb"
    ],
    "icon": "assets/icon.png",
    "category": "Utility",
    "synopsis": "Unofficial ChatGPT Desktop Client",
    "description": "A simple and efficient desktop client for ChatGPT, using Electron to provide a seamless experience on Linux."
  },
  "appImage": {
    "category": "Utility"
  }
}
}